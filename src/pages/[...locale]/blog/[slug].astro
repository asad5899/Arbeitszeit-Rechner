---
import { getCollection, getEntry, render } from 'astro:content';
import { locales, defaultLocale, getLocaleFromUrl, useTranslations, getLocalizedPath } from '../../../utils/i18n';
import SEO from '../../../components/SEO.astro';
import Schema from '../../../components/Schema.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import AuthorBox from '../../../components/AuthorBox.astro';
import CookieConsent from '../../../components/CookieConsent.astro';
import '../../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];

  for (const loc of locales) {
    const localeParam = loc === defaultLocale ? undefined : loc;
    // Filter posts for this locale
    const locPosts = posts.filter(p => p.data.locale === loc);

    for (const post of locPosts) {
      paths.push({
        params: { locale: localeParam, slug: post.id },
        props: { post }
      });
    }
  }
  return paths;
}

const { post } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

// Get author info
const authorEntry = await getEntry('authors', post.data.author);

// Render the Markdown/MDX content using the new render helper
const { Content, headings } = await render(post);

// Generate breadcrumbs
const breadcrumbs = [
  { name: t('nav.blog'), item: getLocalizedPath('/blog', locale) },
  { name: post.data.title, item: getLocalizedPath(`/blog/${post.id}`, locale) }
];

// Calculate words for Schema
const wordCount = post.body ? post.body.split(/\s+/).length : 200;
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    <SEO 
      title={post.data.title} 
      description={post.data.description} 
      locale={locale} 
      ogType="article"
      publishDate={post.data.publishDate.toISOString()}
      updateDate={post.data.updateDate?.toISOString()}
      author={authorEntry?.data.name}
    />
    <Schema 
      type="article"
      title={post.data.title}
      description={post.data.description}
      breadcrumbs={breadcrumbs}
      articleData={{
        headline: post.data.title,
        description: post.data.description,
        image: post.data.image,
        authorName: authorEntry?.data.name || 'Editorial Team',
        datePublished: post.data.publishDate.toISOString(),
        dateModified: post.data.updateDate?.toISOString() || post.data.publishDate.toISOString(),
        wordCount: wordCount,
        category: post.data.category,
      }}
      faqItems={post.data.faq}
    />
  </head>
  <body>
    <Navbar />

    <main class="page">
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbs} />

      <div class="main-grid" style="margin-top: var(--sp-4);">
        <!-- Article Content -->
        <article class="card" style="padding: var(--sp-8);">
          <div style="font-size: var(--text-xs); color: var(--blue-600); font-weight: 700; text-transform: uppercase; margin-bottom: var(--sp-2);">
            {post.data.category}
          </div>
          
          <h1 style="font-size: var(--text-3xl); font-weight: 800; color: var(--gray-950); line-height: 1.25; margin-bottom: var(--sp-4);">
            {post.data.title}
          </h1>

          <div style="display: flex; flex-wrap: wrap; gap: var(--sp-4); font-size: var(--text-xs); color: var(--gray-500); margin-bottom: var(--sp-6); border-bottom: 1px solid var(--gray-200); padding-bottom: var(--sp-4);">
            {authorEntry && (
              <span>
                <strong>{t('blog.author')}:</strong> {authorEntry.data.name}
              </span>
            )}
            <span>
              <strong>{t('blog.published')}:</strong> {post.data.publishDate.toLocaleDateString(locale)}
            </span>
            {post.data.updateDate && (
              <span>
                <strong>{t('blog.updated')}:</strong> {post.data.updateDate.toLocaleDateString(locale)}
              </span>
            )}
            <span>
              <strong>{t('blog.readingTime')}:</strong> {post.data.readingTime || '5 Min.'}
            </span>
          </div>

          <!-- Markdown Content Body -->
          <div class="prose" style="font-size: var(--text-base); color: var(--gray-800); line-height: 1.8;">
            <Content />
          </div>

          <!-- FAQ Sections inside post -->
          {post.data.faq && post.data.faq.length > 0 && (
            <div style="margin-top: var(--sp-8); border-top: 1px solid var(--gray-200); padding-top: var(--sp-6);">
              <h2 style="font-size: var(--text-xl); font-weight: 700; color: var(--blue-900); margin-bottom: var(--sp-4);">
                Häufig gestellte Fragen (FAQ)
              </h2>
              <div style="display: flex; flex-direction: column; gap: var(--sp-4);">
                {post.data.faq.map((f) => (
                  <div>
                    <h4 style="font-size: var(--text-sm); font-weight: 600; color: var(--gray-800); margin-bottom: 4px;">
                      {f.question}
                    </h4>
                    <p style="font-size: var(--text-sm); color: var(--gray-600); margin: 0;">
                      {f.answer}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Sources Bibliography -->
          {post.data.sources && post.data.sources.length > 0 && (
            <div style="margin-top: var(--sp-8); border-top: 1px solid var(--gray-200); padding-top: var(--sp-6);">
              <h2 style="font-size: var(--text-sm); font-weight: 700; color: var(--gray-500); text-transform: uppercase; margin-bottom: var(--sp-3);">
                Quellen und Referenzen
              </h2>
              <ol style="margin-left: var(--sp-4); font-size: var(--text-xs); color: var(--gray-500); line-height: 1.6;">
                {post.data.sources.map((src) => (
                  <li>{src}</li>
                ))}
              </ol>
            </div>
          )}

          <!-- Author Trust EEAT Box -->
          {authorEntry && (
            <AuthorBox 
              name={authorEntry.data.name} 
              bio={authorEntry.data.bio} 
              image={authorEntry.data.image} 
              expertise={authorEntry.data.expertise}
              socials={authorEntry.data.socials}
              reviewerName={post.data.reviewer}
              reviewerBio={post.data.reviewerBio}
            />
          )}
        </article>

        <!-- Sidebar (Table of Contents + Newsletter) -->
        <div style="display: flex; flex-direction: column; gap: var(--sp-6);">
          {headings.length > 0 && (
            <div class="card" style="padding: var(--sp-5);">
              <h3 style="font-size: var(--text-xs); font-weight: 700; color: var(--gray-500); text-transform: uppercase; margin-bottom: var(--sp-3);">
                Inhaltsverzeichnis
              </h3>
              <nav aria-label="Table of contents">
                <ul style="list-style: none; display: flex; flex-direction: column; gap: var(--sp-2);">
                  {headings.map((h) => (
                    <li style={{ marginInlineStart: `${(h.depth - 2) * 12}px` }}>
                      <a href={`#${h.slug}`} style="font-size: var(--text-xs); color: var(--gray-600); text-decoration: none;" class="toc-link">
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- Newsletter Signup Component -->
          <div class="card" style="padding: var(--sp-5); text-align: center; background: var(--blue-50); border: 1px solid var(--blue-100);">
            <h4 style="font-size: var(--text-sm); font-weight: 700; color: var(--blue-900); margin-bottom: 2px;">Newsletter</h4>
            <p style="font-size: var(--text-xs); color: var(--gray-600); margin-bottom: var(--sp-4);">Bleiben Sie auf dem Laufenden.</p>
            <form id="sidebar-newsletter" style="display:flex; flex-direction:column; gap:var(--sp-2);">
              <input type="email" placeholder="E-Mail-Adresse" required style="height:36px; padding:0 var(--sp-3); border:1px solid var(--gray-300); border-radius:var(--radius-sm); font-size:var(--text-xs);" />
              <button type="submit" class="btn-primary" style="height:36px; font-size:var(--text-xs); margin-top:0;">Abonnieren</button>
            </form>
          </div>
        </div>
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>

<style>
  .toc-link:hover {
    color: var(--blue-600) !important;
    text-decoration: underline !important;
  }
  .prose h2 {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--gray-900);
    margin: var(--sp-6) 0 var(--sp-3) 0;
  }
  .prose p {
    margin-bottom: var(--sp-4);
  }
  .prose ul {
    margin-left: var(--sp-6);
    margin-bottom: var(--sp-4);
  }
</style>
