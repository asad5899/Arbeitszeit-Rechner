---
import { locales, defaultLocale, getLocaleFromUrl, useTranslations } from '../../utils/i18n';
import SEO from '../../components/SEO.astro';
import Schema from '../../components/Schema.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(loc => loc !== defaultLocale).map(loc => ({
      params: { locale: loc }
    }))
  ];
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const title = locale === 'de' ? 'Allgemeine Geschäftsbedingungen — Arbeitszeit Rechner' : 'Terms & Conditions — Work Time Calculator';
const description = 'Allgemeine Geschäftsbedingungen zur Nutzung des kostenlosen Arbeitszeit Rechners.';
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} locale={locale} />
    <Schema type="webpage" title={title} description={description} />
  </head>
  <body>
    <Navbar />

    <main class="page">
      <h1 class="page-title">{t('nav.terms')}</h1>
      
      <div class="card" style="margin-top: var(--sp-6); line-height: 1.8;">
        <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-bottom: var(--sp-4);">1. Geltungsbereich</h2>
        <p style="margin-bottom: var(--sp-4);">
          Diese Allgemeinen Geschäftsbedingungen gelten für die Nutzung der Webseite Arbeitszeit Rechner und aller angebotenen Berechnungsdienste.
        </p>

        <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-top: var(--sp-6); margin-bottom: var(--sp-4);">2. Kostenfreie Bereitstellung</h2>
        <p style="margin-bottom: var(--sp-4);">
          Unser Dienst wird vollkommen kostenfrei und ohne Notwendigkeit einer Registrierung zur Verfügung gestellt. Es besteht kein Rechtsanspruch auf dauerhafte Verfügbarkeit der Webseiten oder Tools.
        </p>

        <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-top: var(--sp-6); margin-bottom: var(--sp-4);">3. Haftungsausschluss</h2>
        <p style="margin-bottom: var(--sp-4);">
          Die Berechnungen des Arbeitszeit Rechners dienen der privaten und unverbindlichen Information des Nutzers. Wir übernehmen keine Haftung für die Richtigkeit, Genauigkeit oder Vollständigkeit der Ergebnisse, insbesondere nicht für rechtliche Streitigkeiten oder arbeitsrechtliche Auseinandersetzungen.
        </p>
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
