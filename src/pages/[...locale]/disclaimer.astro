---
import { locales, defaultLocale, getLocaleFromUrl, useTranslations } from '../../utils/i18n';
import SEO from '../../components/SEO.astro';
import Schema from '../../components/Schema.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import TrendingSidebar from '../../components/TrendingSidebar.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(loc => loc !== defaultLocale).map(loc => ({
      params: { locale: loc }
    }))
  ];
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const title = locale === 'de' ? 'Haftungsausschluss — Arbeitszeit Rechner Pro' : 'Disclaimer — Work Time Calculator Pro';
const description = 'Haftungsausschluss bezüglich der Nutzungsergebnisse des Arbeitszeit Rechner Pros.';
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} locale={locale} />
    <Schema type="webpage" title={title} description={description} />
  </head>
  <body>
    <Navbar />

    <main class="page">
      <h1 class="page-title">{t('nav.disclaimer')}</h1>
      
      <div class="main-grid" style="margin-top: var(--sp-6);">
        <div class="card" style="line-height: 1.8;">
          <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-bottom: var(--sp-4);">Keine Rechtsberatung</h2>
          <p style="margin-bottom: var(--sp-4);">
            Die auf dieser Website bereitgestellten Rechentools, Berechnungen und Artikel dienen ausschließlich der allgemeinen Information und stellen keine Rechtsberatung oder Steuerberatung dar. Trotz sorgfältiger Recherche können wir keine Haftung für Fehler oder abweichende behördliche Auslegungen übernehmen.
          </p>
          <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-top: var(--sp-6); margin-bottom: var(--sp-4);">Nutzungsrisiko</h2>
          <p style="margin-bottom: var(--sp-4);">
            Jede Nutzung der Berechnungen erfolgt auf eigenes Risiko des Nutzers. Falls Sie eine rechtlich bindende Berechnung für Lohnabrechnungen oder offizielle Zeiterfassungsnachweise benötigen, wenden Sie sich bitte an eine qualifizierte Fachkraft für Arbeitsrecht oder einen Steuerberater.
          </p>
        </div>
        <TrendingSidebar />
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
