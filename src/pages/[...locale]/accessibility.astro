---
import { locales, defaultLocale, getLocaleFromUrl, useTranslations } from '../../utils/i18n';
import SEO from '../../components/SEO.astro';
import Schema from '../../components/Schema.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import TrendingSidebar from '../../components/TrendingSidebar.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(loc => loc !== defaultLocale).map(loc => ({
      params: { locale: loc }
    }))
  ];
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const title = locale === 'de' ? 'Erklärung zur Barrierefreiheit — Arbeitszeit Rechner Pro' : 'Accessibility Statement — Work Time Calculator Pro';
const description = 'Unsere Erklärung zur Barrierefreiheit gemäß den WCAG 2.2 AA Richtlinien.';
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} locale={locale} />
    <Schema type="webpage" title={title} description={description} />
  </head>
  <body>
    <Navbar />

    <main class="page">
      <h1 class="page-title">{t('nav.accessibility')}</h1>
      
      <div class="main-grid" style="margin-top: var(--sp-6);">
        <div class="card" style="line-height: 1.8;">
          <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-bottom: var(--sp-4);">Unser Engagement</h2>
          <p style="margin-bottom: var(--sp-4);">
            Wir legen großen Wert darauf, dass unsere digitalen Angebote für jeden barrierefrei nutzbar sind. Unser Ziel ist die weitgehende Einhaltung der Richtlinien für barrierefreie Webinhalte (WCAG 2.2) der Stufe AA.
          </p>

          <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-top: var(--sp-6); margin-bottom: var(--sp-4);">Umgesetzte Maßnahmen</h2>
          <ul style="margin-left: var(--sp-6); margin-bottom: var(--sp-4);">
            <li>Verwendung von semantischem HTML für Screenreader-Kompatibilität.</li>
            <li>Tastatursteuerbarkeit aller Eingabefelder und interaktiven Steuerungselemente.</li>
            <li>Hoher Kontrastwert zwischen Text und Hintergrund für verbesserte Lesbarkeit.</li>
            <li>Aria-Beschriftungen zur barrierefreien Erklärung komplexerer Funktionen.</li>
          </ul>
        </div>
        <TrendingSidebar />
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
