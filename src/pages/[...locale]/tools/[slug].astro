---
import { locales, defaultLocale, getLocaleFromUrl, useTranslations } from '../../../utils/i18n';
import SEO from '../../../components/SEO.astro';
import Schema from '../../../components/Schema.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Calculator from '../../../components/Calculator.astro';
import WeeklyTable from '../../../components/WeeklyTable.astro';
import ToolContent from '../../../components/ToolContent.astro';
import TrendingSidebar from '../../../components/TrendingSidebar.astro';
import CookieConsent from '../../../components/CookieConsent.astro';
import { tools, getToolBySlug, getLocalizedTool } from '../../../data/tools';
import '../../../styles/global.css';

export function getStaticPaths() {
  const paths: { params: { locale?: string; slug: string } }[] = [];

  for (const tool of tools) {
    // Default locale (de) — locale param is undefined
    paths.push({ params: { locale: undefined as any, slug: tool.slug } });

    // Other locales
    for (const loc of locales.filter(l => l !== defaultLocale)) {
      paths.push({ params: { locale: loc, slug: tool.slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const tool = getLocalizedTool(slug!, locale);

const title = tool.title;
const description = tool.description;

// FAQ Schema from tool data
const faqSchemaItems = tool.faqItems.map(item => ({
  question: item.q,
  answer: item.a,
}));

// Breadcrumbs
const siteUrl = 'https://www.arbeitszeitrechnerpro.de';
const localePath = locale === defaultLocale ? '' : `/${locale}`;
const breadcrumbs = [
  { name: 'Home', item: `${siteUrl}${localePath}/` },
  { name: 'Tools', item: `${siteUrl}${localePath}/tools/` },
  { name: tool.name, item: `${siteUrl}${localePath}/tools/${tool.slug}/` },
];

const toolKeywords = `${tool.name}, ${tool.name} online, ${tool.name} kostenlos, zeiterfassung, arbeitszeitrechner`;
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    
    <SEO 
      title={title} 
      description={description} 
      keywords={toolKeywords}
      locale={locale} 
    />
    
    <Schema 
      type="webpage" 
      title={title} 
      description={description}
      faqItems={faqSchemaItems}
      breadcrumbs={breadcrumbs}
    />
  </head>
  <body>
    <!-- Navbar -->
    <Navbar />

    <!-- Main Content Page -->
    <main class="page" id="main-content">
      <h1 class="page-title">{tool.name}</h1>
      <p class="page-subtitle">{tool.subtitle}</p>

      <!-- Calculator (same as homepage) -->
      <Calculator />

      <!-- Weekly Log Table -->
      <WeeklyTable />
    </main>

    <!-- Tool Content + Sidebar -->
    <div class="page" style="padding-top: 0;">
      <div class="main-grid">
        <ToolContent tool={tool} />
        <TrendingSidebar />
      </div>
    </div>

    <!-- Footer -->
    <Footer />

    <!-- Cookie Consent Mode v2 -->
    <CookieConsent />

    <!-- Toast Notification structure -->
    <div class="toast" id="toast" role="alert" aria-live="assertive">
      <svg style="width:16px; height:16px; color:var(--success-500); margin-inline-end:var(--sp-2);" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6 9 17l-5-5" />
      </svg>
      <span id="toast-msg">Kopiert!</span>
    </div>
  </body>
</html>
