---
import { getCollection } from 'astro:content';
import { locales, defaultLocale, getLocaleFromUrl, useTranslations, getLocalizedPath } from '../../../utils/i18n';
import SEO from '../../../components/SEO.astro';
import Schema from '../../../components/Schema.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import CookieConsent from '../../../components/CookieConsent.astro';
import TrendingSidebar from '../../../components/TrendingSidebar.astro';
import '../../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(loc => loc !== defaultLocale).map(loc => ({
      params: { locale: loc }
    }))
  ];
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const authors = await getCollection('authors');

const title = locale === 'de' 
  ? 'Unsere Autoren & Experten — Arbeitszeit Rechner Pro' 
  : locale === 'fr'
  ? 'Nos Auteurs & Experts — Calculateur Temps de Travail'
  : locale === 'ar'
  ? 'خبراؤنا وكتابنا — حاسبة ساعات العمل'
  : 'Our Authors & Experts — Work Time Calculator Pro';
const description = 'Lernen Sie das Expertenteam hinter dem Arbeitszeit Rechner Pro kennen — Juristen, HR-Spezialisten und Fachredakteure.';
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} locale={locale} />
    <Schema type="webpage" title={title} description={description} />
  </head>
  <body>
    <Navbar />

    <main class="page">
      <h1 class="page-title">{t('nav.authors')}</h1>
      <p class="page-subtitle">Die Experten hinter unseren Artikeln und Tools.</p>
      
      <div class="main-grid" style="margin-top: var(--sp-6);">
        <div style="display: grid; grid-template-columns: 1fr; gap: var(--sp-6);">
        {authors.map((author) => (
          <div class="card" style="display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
            <div>
              <div style="display: flex; gap: var(--sp-4); align-items: center; margin-bottom: var(--sp-4);">
                <img src={author.data.image} alt={author.data.name} style="width: 64px; height: 64px; border-radius: var(--radius-full); object-fit: cover; border: 2px solid var(--blue-200);" />
                <div>
                  <h2 style="font-size: var(--text-md); font-weight: 700; color: var(--gray-900); margin: 0;">
                    {author.data.name}
                  </h2>
                  <p style="font-size: var(--text-xs); color: var(--blue-600); font-weight: 600; margin: 2px 0 0 0;">
                    {author.data.jobTitle || 'Expert Author'}
                  </p>
                </div>
              </div>
              <p style="font-size: var(--text-sm); color: var(--gray-700); line-height: 1.6; margin-bottom: var(--sp-4);">
                {author.data.bio}
              </p>
            </div>
            
            <a 
              href={getLocalizedPath(`/authors/${author.id}`, locale)} 
              class="btn-outline" 
              style="width: 100%; height: 38px; text-decoration: none;"
            >
              Profil ansehen
            </a>
          </div>
        ))}
        </div>
        <TrendingSidebar />
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
