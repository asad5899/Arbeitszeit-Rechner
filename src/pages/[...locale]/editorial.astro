---
import { locales, defaultLocale, getLocaleFromUrl, useTranslations } from '../../utils/i18n';
import SEO from '../../components/SEO.astro';
import Schema from '../../components/Schema.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { locale: undefined } },
    ...locales.filter(loc => loc !== defaultLocale).map(loc => ({
      params: { locale: loc }
    }))
  ];
}

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);

const title = locale === 'de' ? 'Redaktionelle Richtlinien — Arbeitszeit Rechner' : 'Editorial Policy — Work Time Calculator';
const description = 'Unsere Leitlinien für fachliche Richtigkeit, Verlässlichkeit und Transparenz.';
---

<!DOCTYPE html>
<html lang={locale} dir={t('dir')}>
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} locale={locale} />
    <Schema type="webpage" title={title} description={description} />
  </head>
  <body>
    <Navbar />

    <main class="page">
      <h1 class="page-title">{t('nav.editorial')}</h1>
      
      <div class="card" style="margin-top: var(--sp-6); line-height: 1.8;">
        <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-bottom: var(--sp-4);">Unser Qualitätsanspruch</h2>
        <p style="margin-bottom: var(--sp-4);">
          Jeder Artikel und Leitfaden auf dem Arbeitszeit Rechner folgt strengen journalistischen und fachlichen Richtlinien. Wir stellen sicher, dass alle bereitgestellten Informationen aktuell, faktenbasiert und für Laien verständlich aufbereitet sind.
        </p>

        <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-top: var(--sp-6); margin-bottom: var(--sp-4);">Faktenprüfung & Quellen</h2>
        <p style="margin-bottom: var(--sp-4);">
          Unsere Autoren stützen sich ausschließlich auf verlässliche Primärquellen, darunter offizielle Gesetzestexte, Veröffentlichungen der Gerichte und wissenschaftliche HR-Studien. Eine Liste der genutzten Quellen wird unter jedem Fachartikel transparent ausgewiesen.
        </p>

        <h2 style="font-size: var(--text-xl); color: var(--blue-900); margin-top: var(--sp-6); margin-bottom: var(--sp-4);">Peer Review</h2>
        <p style="margin-bottom: var(--sp-4);">
          Bevor ein Text veröffentlicht wird, durchläuft er eine fachliche Prüfung durch mindestens einen zweiten Experten (Vier-Augen-Prinzip). Der Name des Prüfers (Reviewers) wird am Anfang jedes überprüften Beitrags genannt.
        </p>
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
