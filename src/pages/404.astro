---
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import '../styles/global.css';

const title = 'Seite nicht gefunden (404) — Arbeitszeit Rechner';
const description = 'Die gesuchte Seite konnte nicht gefunden werden.';
---

<!DOCTYPE html>
<html lang="de" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <SEO title={title} description={description} locale="de" robots="noindex, nofollow" />
    <Schema type="webpage" title={title} description={description} />
  </head>
  <body>
    <Navbar />

    <main class="page" style="text-align: center; padding: var(--sp-16) var(--sp-6);">
      <div class="card" style="max-width: 500px; margin: 0 auto; padding: var(--sp-10);">
        <h1 style="font-size: var(--text-4xl); font-weight: 800; color: var(--blue-700); margin-bottom: var(--sp-2);">404</h1>
        <h2 style="font-size: var(--text-xl); font-weight: 700; color: var(--gray-900); margin-bottom: var(--sp-4);">Seite nicht gefunden</h2>
        <p style="font-size: var(--text-sm); color: var(--gray-600); line-height: 1.6; margin-bottom: var(--sp-6);">
          Die von Ihnen aufgerufene Seite existiert nicht oder wurde verschoben.
        </p>
        <a href="/" class="btn-primary" style="text-decoration: none;">
          Zurück zur Startseite
        </a>
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
