---
import { getLocaleFromUrl, useTranslations, getLocalizedPath } from '../utils/i18n';

interface BreadcrumbItem {
  name: string;
  item: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<nav aria-label="Breadcrumb" style="margin-bottom: var(--sp-4);">
  <ol style="display: flex; flex-wrap: wrap; list-style: none; padding: 0; margin: 0; gap: var(--sp-2); align-items: center; font-size: var(--text-xs); color: var(--gray-500); font-weight: 500;">
    <li>
      <a href={getLocalizedPath('/', locale)} style="color: var(--blue-600); text-decoration: none;">
        {t('nav.calculator')}
      </a>
    </li>
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li style="display: flex; align-items: center; gap: var(--sp-2);">
          <svg style="width: 10px; height: 10px; color: var(--gray-400);" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          {isLast ? (
            <span aria-current="page" style="color: var(--gray-800); font-weight: 600;">{item.name}</span>
          ) : (
            <a href={item.item} style="color: var(--blue-600); text-decoration: none;">
              {item.name}
            </a>
          )}
        </li>
      );
    })}
  </ol>
</nav>
