---
import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div class="card weekly-card" id="weekly" style="margin-top: var(--sp-6);">
  <div class="card-title">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    {t('weekly.title')}
  </div>
  <div class="table-wrapper">
    <table class="data-table" id="weekly-table">
      <thead>
        <tr>
          <th>{t('weekly.day')}</th>
          <th>{t('weekly.date')}</th>
          <th>{t('weekly.gross')}</th>
          <th>{t('weekly.break')}</th>
          <th>{t('weekly.net')}</th>
          <th>{t('weekly.overtime')}</th>
          <th>{t('weekly.status')}</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="weekly-body">
        <!-- Rows injected by client JS -->
      </tbody>
      <tfoot id="weekly-foot">
        <tr>
          <td colspan="2">{t('weekly.total')}</td>
          <td id="total-gross">—</td>
          <td id="total-breaks">—</td>
          <td id="total-net">—</td>
          <td id="total-overtime">—</td>
          <td></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>
</div>

<script>
  import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

  const locale = getLocaleFromUrl(window.location.pathname);
  const t = useTranslations(locale);

  const $ = (sel: string) => document.querySelector(sel);
  const STORAGE_KEY = 'az_weekly';
  let format = 'hhmm';

  const dom = {
    weeklyBody: $('#weekly-body'),
    totalGross: $('#total-gross'),
    totalBreaks: $('#total-breaks'),
    totalNet: $('#total-net'),
    totalOvertime: $('#total-overtime'),
  };

  function loadEntries() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]') || [];
    } catch { return []; }
  }

  function saveEntries(entries: any[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
  }

  function fmtHHMM(mins: number) {
    if (mins === null || isNaN(mins)) return '—';
    const sign = mins < 0 ? '-' : '';
    const a = Math.abs(Math.round(mins));
    return `${sign}${String(Math.floor(a / 60)).padStart(2, '0')}:${String(a % 60).padStart(2, '0')}`;
  }

  function fmtDecimal(mins: number) {
    if (mins === null || isNaN(mins)) return '—';
    const sign = mins < 0 ? '-' : '';
    return `${sign}${(Math.abs(mins) / 60).toFixed(2)}`;
  }

  function fmtVal(mins: number) {
    return format === 'decimal' ? fmtDecimal(mins) : fmtHHMM(mins);
  }

  function fmtOvertime(mins: number) {
    if (mins === null || isNaN(mins)) return '—';
    const sign = mins > 0 ? '+' : '';
    return sign + fmtVal(mins);
  }

  function fmtDate(dateStr: string) {
    if (!dateStr) return '—';
    const [y, m, d] = dateStr.split('-');
    return `${d}.${m}.${y}`;
  }

  const daysDe = ['Sonntag', 'Montag', 'Dienstag', 'Mittwoch', 'Donnerstag', 'Freitag', 'Samstag'];
  const daysEn = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const daysFr = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
  const daysAr = ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];

  function getDayName(dateStr: string) {
    if (!dateStr) return '—';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '—';
    const day = d.getDay();
    if (locale === 'ar') return daysAr[day];
    if (locale === 'fr') return daysFr[day];
    if (locale === 'en') return daysEn[day];
    return daysDe[day];
  }

  function deleteEntry(date: string) {
    let entries = loadEntries();
    entries = entries.filter((e: any) => e.date !== date);
    saveEntries(entries);
    renderWeekly();
    window.dispatchEvent(new Event('weekly-updated'));
  }

  function renderWeekly() {
    if (!dom.weeklyBody) return;
    const entries = loadEntries();
    dom.weeklyBody.innerHTML = '';

    if (entries.length === 0) {
      dom.weeklyBody.innerHTML = `
        <tr>
          <td colspan="8" style="text-align:center; color:var(--gray-400); padding:var(--sp-8);">
            ${t('weekly.noEntries')}
          </td>
        </tr>
      `;
      if (dom.totalGross) dom.totalGross.textContent = '—';
      if (dom.totalBreaks) dom.totalBreaks.textContent = '—';
      if (dom.totalNet) dom.totalNet.textContent = '—';
      if (dom.totalOvertime) dom.totalOvertime.textContent = '—';
      return;
    }

    let sumGross = 0, sumBreaks = 0, sumNet = 0, sumOvertime = 0;

    entries.forEach((e: any) => {
      sumGross += e.gross || 0;
      sumBreaks += e.breaks || 0;
      sumNet += e.net || 0;
      sumOvertime += e.overtime || 0;

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${getDayName(e.date)}</td>
        <td>${fmtDate(e.date)}</td>
        <td>${fmtVal(e.gross)}</td>
        <td>${fmtVal(e.breaks)}</td>
        <td><strong>${fmtVal(e.net)}</strong></td>
        <td>${fmtOvertime(e.overtime)}</td>
        <td><span class="status-badge saved">${t('weekly.statusSaved')}</span></td>
        <td>
          <button class="btn-delete-row" data-date="${e.date}" aria-label="Löschen" title="Löschen">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
          </button>
        </td>
      `;
      dom.weeklyBody?.appendChild(tr);
    });

    if (dom.totalGross) dom.totalGross.textContent = fmtVal(sumGross);
    if (dom.totalBreaks) dom.totalBreaks.textContent = fmtVal(sumBreaks);
    if (dom.totalNet) dom.totalNet.textContent = fmtVal(sumNet);
    if (dom.totalOvertime) dom.totalOvertime.textContent = fmtOvertime(sumOvertime);

    dom.weeklyBody.querySelectorAll('.btn-delete-row').forEach((btn: any) => {
      btn.addEventListener('click', () => deleteEntry(btn.dataset.date));
    });
  }

  // Setup Event Listeners
  window.addEventListener('weekly-updated', renderWeekly);
  window.addEventListener('weekly-format-changed', (e: any) => {
    format = e.detail.format;
    renderWeekly();
  });

  renderWeekly();
</script>
