---
/**
 * TrendingSidebar — "Top Trending Tools" widget
 * Shows on every page EXCEPT homepage.
 * Displays the top trending calculators with icons + links.
 */
import { tools } from '../data/tools';
import { getLocaleFromUrl, defaultLocale } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const localePath = locale === defaultLocale ? '' : `/${locale}`;

// Trending tools — curated selection of 8 most searched tools
const trendingSlugs = [
  'arbeitszeit-rechner',
  'stundenlohn-rechner',
  'ueberstunden-rechner',
  'teilzeit-rechner',
  'urlaubstage-rechner',
  'nachtzuschlag-rechner',
  'gleitzeit-rechner',
  'feierabend-rechner',
];

const trendingTools = trendingSlugs
  .map(slug => tools.find(t => t.slug === slug)!)
  .filter(Boolean);

// Smaller icon set for the sidebar
const sidebarIcons: Record<string, string> = {
  'arbeitszeit-rechner': '🕐',
  'stundenlohn-rechner': '💶',
  'ueberstunden-rechner': '⏱️',
  'teilzeit-rechner': '⏰',
  'urlaubstage-rechner': '📅',
  'nachtzuschlag-rechner': '🌙',
  'gleitzeit-rechner': '🔄',
  'feierabend-rechner': '🏠',
};

// All 21 tools for the "Alle Rechner" widget
const allTools = tools;
---

<aside class="trending-sidebar" aria-label="Trending Tools">

  <!-- Top Trending Tools -->
  <div class="sidebar-widget">
    <div class="sidebar-widget-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      <h3>Top Trending</h3>
    </div>
    <ul class="trending-list">
      {trendingTools.map((tool, i) => (
        <li>
          <a href={`${localePath}/tools/${tool.slug}/`} class="trending-item">
            <span class="trending-rank">{i + 1}</span>
            <span class="trending-icon">{sidebarIcons[tool.slug]}</span>
            <span class="trending-name">{tool.name}</span>
            <svg class="trending-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Quick Links: Alle 21 Rechner -->
  <div class="sidebar-widget">
    <div class="sidebar-widget-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <h3>Alle Rechner</h3>
    </div>
    <div class="all-tools-grid">
      {allTools.map((tool) => (
        <a href={`${localePath}/tools/${tool.slug}/`} class="all-tools-link" title={tool.name}>
          {tool.name.replace(' Rechner', '').replace('rechner', '')}
        </a>
      ))}
    </div>
  </div>

  <!-- CTA Widget -->
  <div class="sidebar-widget sidebar-cta">
    <div class="sidebar-cta-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <p class="sidebar-cta-text">Arbeitszeit jetzt berechnen — kostenlos und ohne Anmeldung</p>
    <a href={`${localePath}/`} class="sidebar-cta-btn">Zum Rechner →</a>
  </div>
</aside>

<style>
  .trending-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    position: sticky;
    top: 80px;
  }

  /* Widget container */
  .sidebar-widget {
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-xl);
    padding: var(--sp-5);
    box-shadow: var(--shadow-sm);
  }

  .sidebar-widget-header {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--gray-200);
    color: var(--blue-700);
  }

  .sidebar-widget-header h3 {
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    color: var(--gray-700);
  }

  /* ── Trending list ── */
  .trending-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trending-item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--gray-800);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--dur-fast) var(--ease);
  }

  .trending-item:hover {
    background: var(--blue-50);
    color: var(--blue-700);
  }

  .trending-item:hover .trending-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .trending-item:hover .trending-rank {
    background: var(--blue-600);
    color: var(--white);
  }

  .trending-rank {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: var(--gray-200);
    color: var(--gray-600);
    font-size: 11px;
    font-weight: 700;
    transition: all var(--dur-fast) var(--ease);
  }

  .trending-icon {
    font-size: 16px;
    flex-shrink: 0;
  }

  .trending-name {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trending-arrow {
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all var(--dur-fast) var(--ease);
    color: var(--blue-500);
  }

  /* ── All tools grid ── */
  .all-tools-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
  }

  .all-tools-link {
    display: inline-block;
    padding: 3px var(--sp-2);
    font-size: 11px;
    font-weight: 500;
    color: var(--gray-600);
    background: var(--gray-100);
    border-radius: var(--radius-sm);
    text-decoration: none;
    border: 1px solid transparent;
    transition: all var(--dur-fast) var(--ease);
    line-height: 1.5;
  }

  .all-tools-link:hover {
    background: var(--blue-50);
    color: var(--blue-700);
    border-color: var(--blue-200);
  }

  /* ── CTA Widget ── */
  .sidebar-cta {
    background: linear-gradient(135deg, var(--blue-50) 0%, var(--blue-100) 100%);
    border-color: var(--blue-200);
    text-align: center;
    padding: var(--sp-6) var(--sp-5);
  }

  .sidebar-cta-icon {
    color: var(--blue-500);
    margin-bottom: var(--sp-3);
  }

  .sidebar-cta-text {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--blue-900);
    line-height: 1.5;
    margin: 0 0 var(--sp-4) 0;
  }

  .sidebar-cta-btn {
    display: inline-block;
    padding: var(--sp-2) var(--sp-5);
    background: var(--blue-600);
    color: var(--white);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease);
  }

  .sidebar-cta-btn:hover {
    background: var(--blue-700);
  }

  /* ── Mobile: collapse to horizontal scroll ── */
  @media (max-width: 900px) {
    .trending-sidebar {
      position: static;
      gap: var(--sp-4);
    }
  }
</style>
