---
import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div class="main-grid">
  <!-- ===== LEFT: Calculator Form ===== -->
  <div class="card" id="calculator-form">
    <div class="card-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="8" y2="10.01"/><line x1="12" y1="10" x2="12" y2="10.01"/><line x1="16" y1="10" x2="16" y2="10.01"/><line x1="8" y1="14" x2="8" y2="14.01"/><line x1="12" y1="14" x2="12" y2="14.01"/><line x1="16" y1="14" x2="16" y2="14.01"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
      {t('calc.title')}
    </div>

    <!-- Date -->
    <div class="form-group">
      <label class="form-label" for="input-date">{t('calc.date')}</label>
      <input type="date" class="form-input" id="input-date" aria-label={t('calc.date')}>
      <div class="form-hint success" id="hint-date">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        <span id="hint-date-text"></span>
      </div>
    </div>

    <!-- Time row -->
    <div class="form-row">
      <div class="form-group">
        <label class="form-label" for="input-start">{t('calc.start')}</label>
        <input type="time" class="form-input" id="input-start" value="08:00" required>
        <div class="form-hint" id="hint-start">{t('calc.hintStart')}</div>
      </div>
      <div class="form-group">
        <label class="form-label" for="input-end">{t('calc.end')}</label>
        <input type="time" class="form-input" id="input-end" value="17:00" required>
        <div class="form-hint" id="hint-end">{t('calc.hintEnd')}</div>
      </div>
    </div>

    <!-- Breaks -->
    <div class="form-group">
      <div class="breaks-header">
        <label class="form-label" style="margin-bottom:0;" id="label-breaks">{t('calc.breaks')}</label>
        <button class="btn-add-break" id="btn-add-break" type="button" aria-label={t('calc.addBreak')}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          {t('calc.addBreak')}
        </button>
      </div>
      <div id="breaks-container" role="group" aria-labelledby="label-breaks">
        <div class="break-entry" data-break-index="0">
          <input type="number" class="form-input break-input" value="30" min="0" max="480" step="5" aria-label="Pause 1 in Minuten" placeholder="Minuten">
          <span class="break-unit">Min.</span>
        </div>
      </div>
    </div>

    <!-- Soll-Arbeitszeit -->
    <div class="settings-row">
      <span class="settings-label">{t('calc.targetHours')}:</span>
      <input type="number" class="settings-input" id="input-target" value="8" min="0" max="24" step="0.5" aria-label={t('calc.targetHours')}>
      <span class="settings-unit">{t('calc.hoursPerDay')}</span>
    </div>

    <!-- Button -->
    <button class="btn-primary" id="btn-save" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      {t('calc.save')}
    </button>
  </div>


  <!-- ===== RIGHT: Summary Card ===== -->
  <div class="card summary-card">
    <div class="card-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
      {t('result.title')}
    </div>

    <div class="summary-row">
      <span class="summary-label">{t('result.gross')}</span>
      <span class="summary-value" id="r-gross">—</span>
    </div>
    <div class="summary-row">
      <span class="summary-label">{t('result.breaks')}</span>
      <span class="summary-value" id="r-breaks">—</span>
    </div>
    <div class="summary-divider"></div>
    <div class="summary-row highlight">
      <span class="summary-label">{t('result.net')}</span>
      <span class="summary-value" id="r-net">—</span>
    </div>
    <div class="summary-row" id="overtime-row">
      <span class="summary-label">{t('result.overtime')}</span>
      <span class="summary-value" id="r-overtime">—</span>
    </div>

    <!-- Format Toggle -->
    <div class="summary-format" role="radiogroup" aria-label="Zeitformat">
      <button class="fmt-btn active" data-format="hhmm" role="radio" aria-checked="true">HH:MM</button>
      <button class="fmt-btn" data-format="decimal" role="radio" aria-checked="false">Dezimal</button>
    </div>

    <!-- Actions -->
    <div class="summary-actions">
      <button class="btn-outline" id="btn-copy" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        {t('result.copy')}
      </button>
      <button class="btn-outline" id="btn-reset" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
        {t('result.reset')}
      </button>
    </div>

    <!-- Mini Bar Chart -->
    <div class="chart-section">
      <div class="chart-title">{t('result.chartTitle')}</div>
      <div class="chart-legend">
        <span class="legend-item"><span class="legend-dot ist"></span> {t('result.legendIst')}</span>
        <span class="legend-item"><span class="legend-dot soll"></span> {t('result.legendSoll')}</span>
      </div>
      <div class="chart-container" id="chart-container">
        <!-- Bars are injected by JS -->
      </div>
    </div>
  </div>
</div>

<script>
  // Dynamic Calculator Interactivity (executed fully on client side)
  import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

  const locale = getLocaleFromUrl(window.location.pathname);
  const t = useTranslations(locale);

  const $ = (sel: string) => document.querySelector(sel);
  const $$ = (sel: string) => document.querySelectorAll(sel);

  const dom = {
    inputDate: $('#input-date') as HTMLInputElement | null,
    inputStart: $('#input-start') as HTMLInputElement | null,
    inputEnd: $('#input-end') as HTMLInputElement | null,
    inputTarget: $('#input-target') as HTMLInputElement | null,
    breaksContainer: $('#breaks-container'),
    btnAddBreak: $('#btn-add-break'),
    btnSave: $('#btn-save'),
    btnCopy: $('#btn-copy'),
    btnReset: $('#btn-reset'),

    rGross: $('#r-gross'),
    rBreaks: $('#r-breaks'),
    rNet: $('#r-net'),
    rOvertime: $('#r-overtime'),
    overtimeRow: $('#overtime-row'),

    chartContainer: $('#chart-container'),
    hintDate: $('#hint-date'),
    hintDateText: $('#hint-date-text'),
    toast: $('#toast'),
    toastMsg: $('#toast-msg'),
  };

  let format = 'hhmm';
  let breakCounter = 1;
  interface CalcResult {
    date: string;
    start: string;
    end: string;
    gross: number;
    breaks: number;
    net: number;
    overtime: number;
    targetHours: number;
  }
  let lastResult: CalcResult | null = null;
  const STORAGE_KEY = 'az_weekly';

  function parseTime(str: string) {
    if (!str) return null;
    const [h, m] = str.split(':').map(Number);
    return isNaN(h) || isNaN(m) ? null : h * 60 + m;
  }

  function fmtHHMM(mins: number) {
    if (mins === null || isNaN(mins)) return '—';
    const sign = mins < 0 ? '-' : '';
    const a = Math.abs(Math.round(mins));
    return `${sign}${String(Math.floor(a / 60)).padStart(2, '0')}:${String(a % 60).padStart(2, '0')}`;
  }

  function fmtDecimal(mins: number) {
    if (mins === null || isNaN(mins)) return '—';
    const sign = mins < 0 ? '-' : '';
    return `${sign}${(Math.abs(mins) / 60).toFixed(2)}`;
  }

  function fmtVal(mins: number) {
    return format === 'decimal' ? fmtDecimal(mins) : fmtHHMM(mins);
  }

  function fmtOvertime(mins: number) {
    if (mins === null || isNaN(mins)) return '—';
    const sign = mins > 0 ? '+' : '';
    return sign + fmtVal(mins);
  }

  function fmtDate(dateStr: string) {
    if (!dateStr) return '—';
    const [y, m, d] = dateStr.split('-');
    return `${d}.${m}.${y}`;
  }

  const daysDe = ['Sonntag', 'Montag', 'Dienstag', 'Mittwoch', 'Donnerstag', 'Freitag', 'Samstag'];
  const daysEn = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const daysFr = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
  const daysAr = ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];

  const daysShortDe = ['So', 'Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa'];
  const daysShortEn = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  const daysShortFr = ['Dim', 'Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam'];
  const daysShortAr = ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت'];

  function getDayName(dateStr: string) {
    if (!dateStr) return '—';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '—';
    const day = d.getDay();
    if (locale === 'ar') return daysAr[day];
    if (locale === 'fr') return daysFr[day];
    if (locale === 'en') return daysEn[day];
    return daysDe[day];
  }

  function getDayShort(dateStr: string) {
    if (!dateStr) return '—';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '—';
    const day = d.getDay();
    if (locale === 'ar') return daysShortAr[day];
    if (locale === 'fr') return daysShortFr[day];
    if (locale === 'en') return daysShortEn[day];
    return daysShortDe[day];
  }

  function updateDateHint() {
    if (!dom.inputDate || !dom.hintDateText) return;
    const val = dom.inputDate.value;
    if (!val) {
      dom.hintDateText.textContent = '';
      return;
    }
    dom.hintDateText.textContent = `${getDayName(val)}, ${fmtDate(val)}`;
  }

  function calculate() {
    if (!dom.inputStart || !dom.inputEnd || !dom.inputTarget || !dom.inputDate) return;
    const startMin = parseTime(dom.inputStart.value);
    const endMin = parseTime(dom.inputEnd.value);

    if (startMin === null || endMin === null) {
      clearResults();
      return;
    }

    let grossMinutes = endMin - startMin;
    if (grossMinutes < 0) grossMinutes += 24 * 60;

    const breakInputs = dom.breaksContainer?.querySelectorAll('.break-input');
    let totalBreaks = 0;
    breakInputs?.forEach((input: any) => {
      const v = parseInt(input.value, 10);
      if (!isNaN(v) && v > 0) totalBreaks += v;
    });

    const netMinutes = Math.max(0, grossMinutes - totalBreaks);
    const targetHours = parseFloat(dom.inputTarget.value) || 8;
    const targetMinutes = targetHours * 60;
    const overtime = netMinutes - targetMinutes;

    lastResult = {
      date: dom.inputDate.value,
      start: dom.inputStart.value,
      end: dom.inputEnd.value,
      gross: grossMinutes,
      breaks: totalBreaks,
      net: netMinutes,
      overtime: overtime,
      targetHours: targetHours,
    };

    updateDisplay();
  }

  function clearResults() {
    if (dom.rGross) dom.rGross.textContent = '—';
    if (dom.rBreaks) dom.rBreaks.textContent = '—';
    if (dom.rNet) dom.rNet.textContent = '—';
    if (dom.rOvertime) dom.rOvertime.textContent = '—';
    dom.overtimeRow?.classList.remove('overtime-pos', 'overtime-neg');
    lastResult = null;
  }

  function updateDisplay() {
    if (!lastResult) return;
    const { gross, breaks, net, overtime } = lastResult;

    if (dom.rGross) dom.rGross.textContent = fmtVal(gross);
    if (dom.rBreaks) dom.rBreaks.textContent = fmtVal(breaks);
    if (dom.rNet) dom.rNet.textContent = fmtVal(net);
    if (dom.rOvertime) dom.rOvertime.textContent = fmtOvertime(overtime);

    dom.overtimeRow?.classList.remove('overtime-pos', 'overtime-neg');
    if (overtime > 0) dom.overtimeRow?.classList.add('overtime-pos');
    else if (overtime < 0) dom.overtimeRow?.classList.add('overtime-neg');
  }

  function loadEntries() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]') || [];
    } catch { return []; }
  }

  function saveEntries(entries: any[]) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
  }

  function renderChart() {
    if (!dom.chartContainer) return;
    dom.chartContainer.innerHTML = '';
    const entries = loadEntries();
    const recent = entries.slice(0, 7).reverse();

    if (recent.length === 0) {
      const days = locale === 'ar' ? ['جمعة', 'خميس', 'أربعاء', 'ثلاثاء', 'اثنين'] : ['Mo', 'Di', 'Mi', 'Do', 'Fr'];
      days.forEach((d) => {
        const group = document.createElement('div');
        group.className = 'chart-bar-group';
        group.innerHTML = `
          <div class="chart-bar ist" style="height:0px;"></div>
          <div class="chart-bar soll" style="height:0px;"></div>
          <div class="chart-bar-label">${d}</div>
        `;
        dom.chartContainer?.appendChild(group);
      });
      return;
    }

    const maxVal = Math.max(
      ...recent.map((e: any) => Math.max(e.net || 0, (e.targetHours || 8) * 60)),
      1
    );
    const chartH = 88;

    recent.forEach((e: any) => {
      const istH = Math.max(4, ((e.net || 0) / maxVal) * chartH);
      const sollH = Math.max(4, (((e.targetHours || 8) * 60) / maxVal) * chartH);
      const group = document.createElement('div');
      group.className = 'chart-bar-group';
      group.innerHTML = `
        <div class="chart-bar ist" style="height:${istH}px;" title="${fmtHHMM(e.net)} Ist"></div>
        <div class="chart-bar soll" style="height:${sollH}px;" title="${fmtHHMM((e.targetHours || 8) * 60)} Soll"></div>
        <div class="chart-bar-label">${getDayShort(e.date)}</div>
      `;
      dom.chartContainer?.appendChild(group);
    });
  }

  function saveToWeekly() {
    if (!lastResult || !lastResult.date) {
      showToast(locale === 'ar' ? 'يرجى اختيار التاريخ' : 'Bitte ein Datum auswählen');
      return;
    }
    const entries = loadEntries();
    const idx = entries.findIndex((e: any) => e.date === lastResult?.date);

    if (idx >= 0) {
      entries[idx] = lastResult;
    } else {
      entries.push(lastResult);
    }

    entries.sort((a: any, b: any) => b.date.localeCompare(a.date));
    if (entries.length > 14) entries.length = 14;

    saveEntries(entries);
    renderChart();

    // Trigger local weekly table reload
    window.dispatchEvent(new Event('weekly-updated'));
    showToast(locale === 'ar' ? 'تم الحفظ بنجاح' : 'Erfolgreich gespeichert');
  }

  let toastTimer: any = null;
  function showToast(msg: string) {
    if (!dom.toast || !dom.toastMsg) return;
    dom.toastMsg.textContent = msg;
    dom.toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => dom.toast?.classList.remove('show'), 2200);
  }

  // Setup Event listeners
  function init() {
    // Set default date to today
    if (dom.inputDate) {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, '0');
      const d = String(now.getDate()).padStart(2, '0');
      dom.inputDate.value = `${y}-${m}-${d}`;
      updateDateHint();
      dom.inputDate.addEventListener('input', updateDateHint);
    }

    dom.inputStart?.addEventListener('input', calculate);
    dom.inputEnd?.addEventListener('input', calculate);
    dom.inputTarget?.addEventListener('input', calculate);

    dom.breaksContainer?.querySelectorAll('.break-input').forEach((i) => {
      i.addEventListener('input', calculate);
    });

    dom.btnAddBreak?.addEventListener('click', () => {
      breakCounter++;
      const entry = document.createElement('div');
      entry.className = 'break-entry';
      entry.innerHTML = `
        <input type="number" class="form-input break-input" value="15" min="0" max="480" step="5" placeholder="Minuten">
        <span class="break-unit">Min.</span>
        <button class="btn-remove-break" type="button" aria-label="Entfernen">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
        </button>
      `;
      dom.breaksContainer?.appendChild(entry);
      entry.querySelector('.btn-remove-break')?.addEventListener('click', () => {
        entry.remove();
        calculate();
      });
      entry.querySelector('.break-input')?.addEventListener('input', calculate);
      calculate();
    });

    dom.btnSave?.addEventListener('click', saveToWeekly);

    // Format toggles
    $$('.fmt-btn').forEach((b) => {
      b.addEventListener('click', () => {
        const fmt = b.getAttribute('data-format') || 'hhmm';
        format = fmt;
        $$('.fmt-btn').forEach((btn) => {
          btn.classList.toggle('active', btn.getAttribute('data-format') === fmt);
        });
        updateDisplay();
        renderChart();
        window.dispatchEvent(new CustomEvent('weekly-format-changed', { detail: { format } }));
      });
    });

    dom.btnReset?.addEventListener('click', () => {
      if (dom.inputStart) dom.inputStart.value = '08:00';
      if (dom.inputEnd) dom.inputEnd.value = '17:00';
      if (dom.inputTarget) dom.inputTarget.value = '8';
      if (dom.breaksContainer) {
        dom.breaksContainer.innerHTML = `
          <div class="break-entry" data-break-index="0">
            <input type="number" class="form-input break-input" value="30" min="0" max="480" step="5" placeholder="Minuten">
            <span class="break-unit">Min.</span>
          </div>
        `;
        dom.breaksContainer.querySelector('.break-input')?.addEventListener('input', calculate);
      }
      calculate();
      showToast(locale === 'ar' ? 'تمت إعادة التعيين' : 'Zurückgesetzt');
    });

    dom.btnCopy?.addEventListener('click', async () => {
      if (!lastResult) return;
      const r = lastResult;
      const text = [
        `Arbeitszeit — ${getDayName(r.date)}, ${fmtDate(r.date)}`,
        `Beginn: ${r.start}  |  Ende: ${r.end}`,
        `Brutto: ${fmtHHMM(r.gross)}  |  Pause: ${fmtHHMM(r.breaks)}`,
        `Netto:  ${fmtHHMM(r.net)} (${fmtDecimal(r.net)} Std)`,
        `Überst: ${fmtOvertime(r.overtime)}`,
      ].join('\n');
      try {
        await navigator.clipboard.writeText(text);
        showToast(locale === 'ar' ? 'تم نسخ النتائج' : 'Ergebnis kopiert!');
      } catch {
        showToast(locale === 'ar' ? 'فشل النسخ' : 'Kopieren fehlgeschlagen');
      }
    });

    // Listen to parent updates
    window.addEventListener('weekly-updated', renderChart);

    calculate();
    renderChart();
  }

  // Load
  init();
</script>
