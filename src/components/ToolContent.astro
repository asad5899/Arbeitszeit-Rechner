---
import type { ToolDef } from '../data/tools';

interface Props {
  tool: ToolDef;
}

const { tool } = Astro.props;
---

<div class="content-area" id="content-sections">

  <!-- Intro -->
  <section class="content-section" id="tool-intro">
    <h2 class="content-h2">{tool.sections[0].heading}</h2>
    <p class="content-intro">{tool.sections[0].text}</p>
  </section>

  <div class="section-divider"></div>

  <!-- Section 2 -->
  <section class="content-section" id="tool-section-2">
    <h2 class="content-h2">{tool.sections[1].heading}</h2>
    <p class="content-p"><strong>{tool.sections[1].text}</strong></p>
  </section>

  <div class="section-divider"></div>

  <!-- Section 3 -->
  <section class="content-section" id="tool-section-3">
    <h2 class="content-h2">{tool.sections[2].heading}</h2>
    <p class="content-p">{tool.sections[2].text}</p>
  </section>

  <div class="section-divider"></div>

  <!-- FAQ -->
  <section class="content-section" id="tool-faq">
    <h2 class="content-h2">Häufig gestellte Fragen</h2>

    <div class="faq-list">
      {tool.faqItems.map((item) => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{item.q}</span>
            <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Features -->
  <section class="content-section" id="tool-features">
    <h2 class="content-h2">Warum dieser Rechner?</h2>

    <div class="feature-grid">
      {tool.features.map((f) => (
        <div class="feature-card">
          <div class="feature-icon">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-section">
    <h2>{tool.ctaTitle}</h2>
    <p>{tool.ctaText}</p>
    <a href="#calculator-form" class="cta-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      {tool.ctaTitle}
    </a>
  </div>

</div>
