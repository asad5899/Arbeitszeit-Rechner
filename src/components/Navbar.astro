---
import { getLocaleFromUrl, useTranslations, getLocalizedPath, locales } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;

// Remove current locale from path to calculate path for switcher
let cleanPath = currentPath;
locales.forEach((loc) => {
  if (currentPath.startsWith(`/${loc}/`)) {
    cleanPath = currentPath.substring(loc.length + 1);
  } else if (currentPath === `/${loc}`) {
    cleanPath = '/';
  }
});
if (!cleanPath.startsWith('/')) {
  cleanPath = '/' + cleanPath;
}

const navLinks = [
  { href: getLocalizedPath('/', locale), label: t('nav.calculator'), active: currentPath === getLocalizedPath('/', locale) },
  { href: `${getLocalizedPath('/', locale)}#weekly`, label: t('nav.weekly'), active: false },
  { href: getLocalizedPath('/blog', locale), label: t('nav.blog'), active: currentPath.includes('/blog') },
  { href: getLocalizedPath('/faq', locale), label: t('nav.faq'), active: currentPath.includes('/faq') },
  { href: getLocalizedPath('/about', locale), label: t('nav.about'), active: currentPath.includes('/about') },
];
---

<nav class="navbar" role="navigation" aria-label={t('nav.calculator')}>
  <div class="navbar-inner">
    <a href={getLocalizedPath('/', locale)} class="nav-logo" aria-label="Arbeitszeit Rechner Pro">
      <div class="nav-logo-icon" aria-hidden="true" style="background: transparent;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 512 512" style="width: 100%; height: 100%;">
          <defs>
            <linearGradient id="bgGradIcon" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#3b82f6" />
              <stop offset="100%" stop-color="#1e40af" />
            </linearGradient>
          </defs>
          <circle cx="256" cy="256" r="236" fill="url(#bgGradIcon)" />
          <rect x="128" y="148" width="256" height="240" rx="24" fill="#ffffff" />
          <path d="M128 172c0-13.25 10.75-24 24-24h208c13.25 0 24 10.75 24 24v32H128v-32Z" fill="#eff6ff" />
          <line x1="168" y1="260" x2="344" y2="260" stroke="#cbd5e1" stroke-width="6" stroke-linecap="round" />
          <line x1="168" y1="300" x2="344" y2="300" stroke="#cbd5e1" stroke-width="6" stroke-linecap="round" />
          <line x1="168" y1="340" x2="260" y2="340" stroke="#cbd5e1" stroke-width="6" stroke-linecap="round" />
          <rect x="176" y="116" width="16" height="48" rx="8" fill="#cbd5e1" />
          <rect x="179" y="116" width="10" height="48" rx="5" fill="#e2e8f0" />
          <rect x="320" y="116" width="16" height="48" rx="8" fill="#cbd5e1" />
          <rect x="329" y="116" width="10" height="48" rx="5" fill="#e2e8f0" />
          <circle cx="316" cy="324" r="76" fill="#3b82f6" stroke="#ffffff" stroke-width="12" />
          <circle cx="316" cy="324" r="64" fill="#eff6ff" />
          <line x1="316" y1="268" x2="316" y2="274" stroke="#1e3a8a" stroke-width="4" stroke-linecap="round" />
          <line x1="372" y1="324" x2="366" y2="324" stroke="#1e3a8a" stroke-width="4" stroke-linecap="round" />
          <line x1="316" y1="380" x2="316" y2="374" stroke="#1e3a8a" stroke-width="4" stroke-linecap="round" />
          <line x1="260" y1="324" x2="266" y2="324" stroke="#1e3a8a" stroke-width="4" stroke-linecap="round" />
          <line x1="316" y1="324" x2="316" y2="290" stroke="#1e3a8a" stroke-width="6" stroke-linecap="round" />
          <line x1="316" y1="324" x2="344" y2="336" stroke="#2563eb" stroke-width="6" stroke-linecap="round" />
          <circle cx="316" cy="324" r="8" fill="#1e2a5e" />
        </svg>
      </div>
      <span class="nav-logo-text">Arbeitszeit <span>Rechner</span></span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class={`nav-link ${link.active ? 'active' : ''}`}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Language switcher + User info -->
    <div style="display: flex; align-items: center; gap: var(--sp-4);">
      <!-- Language picker dropdown -->
      <div class="lang-switcher" style="position: relative;">
        <select 
          id="lang-select" 
          aria-label="Sprache wechseln / Change Language"
          style="padding: var(--sp-1) var(--sp-2); border: 1px solid var(--gray-300); border-radius: var(--radius-sm); font-size: var(--text-xs); font-family: var(--font); background: var(--white); cursor: pointer;"
        >
          {locales.map((loc) => (
            <option value={getLocalizedPath(cleanPath, loc)} selected={loc === locale}>
              {loc === 'de' ? 'DE' : loc === 'en' ? 'EN' : loc === 'fr' ? 'FR' : 'AR'}
            </option>
          ))}
        </select>
      </div>

      <div class="nav-user">
        <div class="nav-avatar" aria-hidden="true">MS</div>
        <span class="nav-user-name">M. Schmidt</span>
      </div>
    </div>

    <button class="nav-hamburger" id="nav-toggle" aria-label="Menü öffnen" type="button" aria-expanded="false" aria-controls="mobile-menu">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" style="display: none; position: fixed; inset: var(--nav-h) 0 0 0; background: var(--white); z-index: 40; border-top: 1px solid var(--gray-200); padding: var(--sp-6);" role="dialog" aria-modal="true" aria-label="Mobile Navigation">
  <ul style="list-style: none; display: flex; flex-direction: column; gap: var(--sp-4);">
    {navLinks.map((link) => (
      <li>
        <a href={link.href} class="mobile-nav-link" style="font-size: var(--text-lg); font-weight: 600; color: var(--gray-800); text-decoration: none; display: block; padding: var(--sp-2) 0;">
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  // Mobile menu toggle
  const toggleBtn = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.style.display = expanded ? 'none' : 'block';
    });
  }

  // Language switcher redirect
  const langSelect = document.getElementById('lang-select') as HTMLSelectElement | null;
  if (langSelect) {
    langSelect.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      if (target.value) {
        window.location.href = target.value;
      }
    });
  }
</script>
