---
import { getLocaleFromUrl, useTranslations } from '../utils/i18n';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div class="card" style="margin-top: var(--sp-8); background: var(--blue-50); border: 1px solid var(--blue-200); padding: var(--sp-8); border-radius: var(--radius-xl); text-align: center;">
  <h3 style="font-size: var(--text-lg); font-weight: 700; color: var(--blue-900); margin-bottom: var(--sp-2);">
    Newsletter abonnieren
  </h3>
  <p style="font-size: var(--text-sm); color: var(--gray-600); margin-bottom: var(--sp-6); max-width: 480px; margin-inline: auto;">
    Erhalten Sie wöchentlich Tipps zur Arbeitszeitgestaltung, Arbeitsrecht-Updates und Produktivitäts-Tricks direkt in Ihr Postfach.
  </p>
  <form id="newsletter-form" style="display: flex; gap: var(--sp-2); max-width: 420px; margin: 0 auto; flex-wrap: wrap;">
    <input type="email" placeholder="Ihre E-Mail-Adresse" required style="flex: 1; min-width: 220px; height: 44px; padding: 0 var(--sp-4); border: 1.5px solid var(--gray-300); border-radius: var(--radius-md); font-family: var(--font);" />
    <button type="submit" class="btn-primary" style="margin-top: 0; width: auto; height: 44px; padding: 0 var(--sp-6);">
      Abonnieren
    </button>
  </form>
  <div id="newsletter-success" style="display: none; color: var(--success-600); font-weight: 600; margin-top: var(--sp-4); font-size: var(--text-sm);">
    Vielen Dank! Sie haben sich erfolgreich angemeldet.
  </div>
</div>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const success = document.getElementById('newsletter-success');

  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.style.display = 'none';
      success.style.display = 'block';
    });
  }
</script>
