---

<section class="tools-grid-section" id="alle-rechner">
  <div class="tools-grid-container">
    <div class="tools-grid-header">
      <span class="tools-grid-badge">21 kostenlose Tools</span>
      <h2 class="tools-grid-title">Alle Rechner im Überblick</h2>
      <p class="tools-grid-subtitle">Von Arbeitszeit bis Zuschlag — finde den passenden Rechner für deine Anforderung.</p>
    </div>

    <div class="tools-grid">
      {tools.map((tool) => {
        const meta = toolMeta[tool.slug];
        return (
          <a href={`${localePath}/tools/${tool.slug}/`} class="tool-card" style={`--tool-color: ${meta.color}; --tool-gradient: ${meta.gradient};`}>
            <div class="tool-card-icon" set:html={meta.icon} />
            <div class="tool-card-body">
              <h3 class="tool-card-title">{tool.name}</h3>
              <p class="tool-card-desc">{tool.subtitle}</p>
            </div>
            <div class="tool-card-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .tools-grid-section {
    padding: var(--sp-16) var(--sp-6);
    background: var(--gray-50);
    border-top: 1px solid var(--gray-300);
  }

  .tools-grid-container {
    max-width: 1120px;
    margin: 0 auto;
  }

  .tools-grid-header {
    text-align: center;
    margin-bottom: var(--sp-12);
  }

  .tools-grid-badge {
    display: inline-block;
    padding: var(--sp-1) var(--sp-4);
    background: var(--blue-100);
    color: var(--blue-700);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: var(--sp-4);
  }

  .tools-grid-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--gray-900);
    margin: 0 0 var(--sp-3) 0;
    line-height: 1.2;
  }

  .tools-grid-subtitle {
    font-size: var(--text-lg);
    color: var(--gray-600);
    margin: 0;
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5);
  }

  /* ── Card ── */
  .tool-card {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-5);
    background: var(--white);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-xl);
    text-decoration: none;
    color: inherit;
    transition: all var(--dur) var(--ease);
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--tool-gradient);
    opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }

  .tool-card:hover {
    border-color: var(--tool-color);
    box-shadow: var(--shadow-lg), 0 0 0 1px color-mix(in srgb, var(--tool-color) 15%, transparent);
    transform: translateY(-2px);
  }

  .tool-card:hover::before {
    opacity: 1;
  }

  .tool-card:hover .tool-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--tool-color);
  }

  .tool-card:hover .tool-card-icon {
    transform: scale(1.08);
  }

  /* ── Icon ── */
  .tool-card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    padding: 6px;
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--tool-color) 10%, transparent);
    color: var(--tool-color);
    transition: transform var(--dur) var(--ease);
  }

  .tool-card-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* ── Body ── */
  .tool-card-body {
    flex: 1;
    min-width: 0;
  }

  .tool-card-title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--gray-900);
    margin: 0 0 var(--sp-1) 0;
    line-height: 1.3;
  }

  .tool-card-desc {
    font-size: var(--text-sm);
    color: var(--gray-600);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Arrow ── */
  .tool-card-arrow {
    flex-shrink: 0;
    align-self: center;
    opacity: 0;
    transform: translateX(-6px);
    transition: all var(--dur) var(--ease);
    color: var(--gray-400);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .tools-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--sp-4);
    }
  }

  @media (max-width: 560px) {
    .tools-grid-section {
      padding: var(--sp-10) var(--sp-4);
    }

    .tools-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-3);
    }

    .tools-grid-title {
      font-size: var(--text-2xl);
    }

    .tool-card {
      padding: var(--sp-4);
      gap: var(--sp-3);
    }

    .tool-card-icon {
      width: 38px;
      height: 38px;
      padding: 5px;
    }

    .tool-card-arrow {
      opacity: 0.5;
      transform: translateX(0);
    }
  }
</style>
