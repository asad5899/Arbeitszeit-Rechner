  },
  'feiertagszuschlag-rechner': {
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M24 6l3 9h9l-7 5 3 9-8-6-8 6 3-9-7-5h9z" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round" fill="currentColor" opacity="0.15"/><rect x="12" y="32" width="24" height="10" rx="2" stroke="currentColor" stroke-width="2.5"/></svg>`,
    color: '#eab308', gradient: 'linear-gradient(135deg, #eab308 0%, #ca8a04 100%)'
  },
  'sonntagszuschlag-rechner': {
